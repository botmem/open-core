# Self-hosted isolated E2E environment
PORT=12412
AUTH_PROVIDER=local
FRONTEND_URL=http://localhost:22412

DATABASE_URL=postgresql://botmem:botmem@postgres:5432/botmem
REDIS_URL=redis://redis:6379
TYPESENSE_URL=http://typesense:8108
TYPESENSE_API_KEY=botmem-ts-key

AI_BACKEND=ollama
EMBED_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TEXT_MODEL=qwen3:0.6b
OLLAMA_VL_MODEL=qwen3-vl:2b

APP_SECRET=replace-with-random-secret
JWT_ACCESS_SECRET=replace-with-random-secret
JWT_REFRESH_SECRET=replace-with-random-secret
OAUTH_JWT_SECRET=replace-with-random-secret

# Connector credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional for openrouter-specific connector tests
OPENROUTER_API_KEY=

SYNC_DEBUG_LIMIT=0
