{
  "name": "botmem",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @botmem/api dev",
    "dev:all": "turbo watch dev --concurrency 20",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"apps/*/src/**/*.{ts,tsx}\" \"packages/*/src/**/*.{ts,tsx}\" \"packages/connectors/*/src/**/*.{ts,tsx}\"",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.0.0",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
