{
  "name": "@botmem/openclaw-plugin",
  "version": "0.0.0",
  "description": "OpenClaw plugin for Botmem — personal memory search across emails, messages, photos, and more",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/botmem/botmem.git",
    "directory": "packages/openclaw-plugin"
  },
  "homepage": "https://github.com/botmem/botmem/tree/main/packages/openclaw-plugin",
  "keywords": [
    "botmem",
    "openclaw",
    "memory",
    "rag",
    "plugin",
    "agent"
  ],
  "main": "dist/index.js",
