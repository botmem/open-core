# ===========================
# Botmem Environment Variables
# Copy this file to .env and adjust values for your setup
# ===========================

# --- Auth Provider ---
# "local" for self-hosted (email/password), "firebase" for managed/cloud
AUTH_PROVIDER=local
VITE_AUTH_PROVIDER=local

# --- Core ---
PORT=12412
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://botmem:botmem@localhost:5432/botmem
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
FRONTEND_URL=http://localhost:12412
PLUGINS_DIR=./plugins

# --- Ollama (AI Inference) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TEXT_MODEL=qwen3:0.6b
OLLAMA_VL_MODEL=qwen3-vl:2b
OLLAMA_RERANKER_MODEL=sam860/qwen3-reranker:0.6b-Q8_0

# Embedding vector dimension — auto-detected from model name.
# Override only if using an unknown model:
# EMBED_DIMENSION=768

# --- Embedding Backend (optional, defaults to AI_BACKEND) ---
# Decouple embedding from generation. Use Gemini for multimodal embeddings
# (images + text in the same vector space) while keeping Ollama/OpenRouter for text generation.
# EMBED_BACKEND=gemini
# GEMINI_API_KEY=your-google-api-key
# GEMINI_EMBED_MODEL=gemini-embedding-2-preview
# GEMINI_EMBED_DIMENSIONS=3072

# --- Auth (JWT) ---
# IMPORTANT: Change these in production!
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
OAUTH_JWT_SECRET=dev-oauth-jwt-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Encryption ---
# IMPORTANT: Change in production! Used to encrypt connector credentials at rest.
APP_SECRET=dev-app-secret-change-in-production

# --- SMTP (Password Reset Emails) ---
# Leave commented to use console fallback in dev
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# --- Sync ---
SYNC_DEBUG_LIMIT=500

# --- Scheduled Tasks ---
DECAY_CRON=0 3 * * *

# --- PostHog Analytics (optional) ---
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://your-posthog-host.example.com
# POSTHOG_LOG_SERVICE_NAME=botmem-api
# POSTHOG_LOG_MIN_LEVEL=log

# --- Gmail OAuth (optional) ---
# GMAIL_CLIENT_ID=your-google-client-id
# GMAIL_CLIENT_SECRET=your-google-client-secret

# --- Slack (optional) ---
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret
