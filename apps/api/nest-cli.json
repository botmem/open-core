{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "swc",
    "deleteOutDir": true,
    "assets": [
      { "include": "db/migrations/**", "watchAssets": true },
      { "include": "swagger-theme.css", "watchAssets": true }
    ],
    "plugins": ["@nestjs/swagger"]
  }
}
